# Example secrets file — copy to project_secrets.py and fill in your keys.
# Only the key for your chosen provider is required.

# --- Provider selection ---
# Options: "google", "openrouter", "openai", "anthropic"
LLM_PROVIDER = "google"

# --- Google Gemini ---
GEMINI_API_KEY = "your_gemini_api_key_here"

# --- OpenRouter (routes to many models via one key) ---
OPENROUTER_API_KEY = "your_openrouter_api_key_here"

# --- OpenAI ---
OPENAI_API_KEY = "your_openai_api_key_here"

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY = "your_anthropic_api_key_here"
